# ╔══════════════════════════════════════════════════════════════════════╗
# ║  MOLTY ROYALE AI AGENT — RAILWAY VARIABLES                         ║
# ║  Copy these to Railway Dashboard → Variables tab                   ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WAJIB DIISI (kamu isi manual di Railway Variables)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AGENT_NAME=                    # Nama bot agent (max 50 chars)
ROOM_MODE=free                 # free = selalu free room (default)
                               # auto = paid kalau ready, fallback free
                               # paid = hanya paid room
LOG_LEVEL=INFO                 # DEBUG / INFO / WARNING

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FIRST-RUN INTAKE (setup.md pertanyaan 1-9, jawaban via env var)
# Semua default = true/auto, jadi zero-config deploy langsung jalan
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ADVANCED_MODE=true             # Q1-3: auto-generate Owner EOA + Agent wallet
AUTO_WHITELIST=true            # Q4: auto-check + auto-approve whitelist
AUTO_SC_WALLET=true            # Q6: auto-create MoltyRoyale SC Wallet
ENABLE_MEMORY=true             # Q7: cross-game learning (molty-royale-context.json)
ENABLE_AGENT_TOKEN=false       # Q8: agent token registration (skip dulu)
AUTO_IDENTITY=true             # Q9: auto-register ERC-8004 identity

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAILWAY AUTO-SYNC (agar credentials persist walau container restart)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
RAILWAY_API_TOKEN=             # Buat di: https://railway.com/account/tokens

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AUTO-GENERATED (JANGAN DIISI — bot akan mengisi otomatis)
# Setelah first-run, bot auto-save ke Railway Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
API_KEY=                       # Auto: dari POST /accounts response
AGENT_WALLET_ADDRESS=          # Auto: generated Agent EOA
AGENT_PRIVATE_KEY=             # Auto: generated Agent private key
OWNER_EOA=                     # Auto: generated Owner EOA address
OWNER_PRIVATE_KEY=             # Auto: generated Owner private key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AIRDROP CONFIGURATION
# Konfigurasi untuk klaim dan tracking airdrop rewards
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ENABLE_AIRDROP=true            # Aktifkan fitur airdrop (true/false)
AIRDROP_WHITELIST_ONLY=false   # Hanya klaim untuk whitelist addresses (true/false)
AIRDROP_MIN_BALANCE=0          # Minimum balance untuk klaim (dalam token decimals)
AIRDROP_GAS_PRIORITY_FEE=     # Priority fee untuk gas (dalam Gwei, kosong = auto)
AIRDROP_MAX_GAS_PRICE=100      # Max gas price yang bersedia dibayar (Gwei)
AIRDROP_CLAIM_BATCH_SIZE=10    # Jumlah address per batch klaim
AIRDROP_RETRY_ATTEMPTS=3       # Jumlah percobaan ulang jika klaim gagal
AIRDROP_RETRY_DELAY=60         # Delay antar percobaan (detik)
AIRDROP_NOTIFY_WEBHOOK=        # Webhook URL untuk notifikasi airdrop (opsional)
AIRDROP_AUTO_CLAIM=true        # Klaim otomatis saat airdrop tersedia (true/false)
AIRDROP_CLAIM_DEADLINE=        # Batas waktu klaim (ISO format, kosong = tidak ada batas)
